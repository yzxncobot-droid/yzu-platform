// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  MERIL
  ADMIN
  OWNER
}

enum TopupStatus {
  PENDING_CONFIRMATION
  SUCCESS
  REJECTED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum NotificationType {
  TOPUP_APPROVED
  TOPUP_REJECTED
  SUBSCRIPTION_ACTIVE
  SUBSCRIPTION_EXPIRED
  VIDEO_PURCHASED
  COMMENT_REPLY
  VIDEO_LIKE
}

// ==================== MODELS ====================

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  username          String             @unique
  password          String
  fullName          String?
  profileImage      String?
  role              UserRole           @default(MERIL)
  isActive          Boolean            @default(true)
  isSuspended       Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  // Relations
  wallet            Wallet?
  transactions      Transaction[]
  topupRequests     TopupRequest[]
  subscriptions     UserSubscription[]
  videos            Video[]
  videoPurchases    VideoPurchase[]
  comments          Comment[]
  likes             Like[]
  viewHistory       ViewHistory[]
  notifications     Notification[]
  topupLeaderboard  TopupLeaderboard[]

  @@index([email])
  @@index([role])
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Decimal  @default(0) @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Transaction {
  id              String   @id @default(cuid())
  userId          String
  type            String   // TOPUP, VIDEO_PURCHASE, SUBSCRIPTION_PURCHASE
  amount          Decimal  @db.Decimal(12, 2)
  description     String?
  referenceId     String?  // Link to TopupRequest or VideoPurchase
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model TopupRequest {
  id                String        @id @default(cuid())
  userId            String
  nominal           Decimal       @db.Decimal(12, 2)
  proofImage        String?
  status            TopupStatus   @default(PENDING_CONFIRMATION)
  rejectionReason   String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  approvedAt        DateTime?
  approvedBy        String?

  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model SubscriptionPlan {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @db.Text
  price       Decimal  @db.Decimal(12, 2)
  durationDay Int
  badge       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions UserSubscription[]

  @@index([isActive])
}

model UserSubscription {
  id              String               @id @default(cuid())
  userId          String
  planId          String
  status          SubscriptionStatus   @default(ACTIVE)
  startDate       DateTime             @default(now())
  endDate         DateTime
  autoRenew       Boolean              @default(false)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan            SubscriptionPlan     @relation(fields: [planId], references: [id])

  @@unique([userId, planId, status])
  @@index([userId])
  @@index([status])
  @@index([endDate])
}

model VideoCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  icon      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  videos    Video[]

  @@index([isActive])
}

model Video {
  id              String   @id @default(cuid())
  title           String
  description     String?  @db.Text
  thumbnail       String?
  videoUrl        String
  categoryId      String
  adminId         String
  duration        Int      // in seconds
  isPremium       Boolean  @default(false)
  price           Decimal? @db.Decimal(12, 2)
  viewCount       Int      @default(0)
  likeCount       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category        VideoCategory    @relation(fields: [categoryId], references: [id])
  admin           User             @relation(fields: [adminId], references: [id], onDelete: Cascade)
  purchases       VideoPurchase[]
  comments        Comment[]
  likes           Like[]
  viewHistory     ViewHistory[]

  @@index([categoryId])
  @@index([adminId])
  @@index([isPremium])
  @@index([createdAt])
}

model VideoPurchase {
  id        String   @id @default(cuid())
  userId    String
  videoId   String
  price     Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
  @@index([userId])
  @@index([videoId])
}

model Comment {
  id        String   @id @default(cuid())
  videoId   String
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([videoId])
  @@index([userId])
}

model Like {
  id        String   @id @default(cuid())
  videoId   String
  userId    String
  createdAt DateTime @default(now())

  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([videoId, userId])
  @@index([videoId])
  @@index([userId])
}

model ViewHistory {
  id            String   @id @default(cuid())
  videoId       String
  userId        String
  watchDuration Int      // in seconds
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  video         Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([videoId, userId])
  @@index([videoId])
  @@index([userId])
  @@index([createdAt])
}

model Notification {
  id        String             @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String             @db.Text
  isRead    Boolean            @default(false)
  data      String?            @db.Json
  createdAt DateTime           @default(now())

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model TopupLeaderboard {
  id        String   @id @default(cuid())
  userId    String
  period    String   // DAILY, WEEKLY, MONTHLY, ALL_TIME
  totalTopup Decimal @db.Decimal(12, 2)
  rank      Int
  badge     String?  // GOLD, SILVER, BRONZE
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period])
  @@index([period])
  @@index([rank])
}

model WebsiteSetting {
  id               String   @id @default(cuid())
  websiteName      String   @default("Yzu Platform")
  logo             String?
  favicon          String?
  bannerImage      String?
  footerText       String?  @db.Text
  faqJson          String?  @db.Json
  whatsappLink     String?
  chatLogo         String?
  themeColor       String   @default("#2563eb")
  qrisImage        String?
  qrisUpdatedAt    DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([id])
}
